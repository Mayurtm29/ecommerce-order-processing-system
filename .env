# SQLite database file (created after migrations). Path is relative to project root.
DATABASE_URL="file:./dev.db"

# HTTP port (optional; defaults to 3000)
PORT=3000

# JWT signing (required for login and /orders). Use a long random string in production.
JWT_SECRET="change-me-to-a-long-random-secret"

# Access token lifetime (optional; e.g. 1d, 12h, 3600s)
JWT_EXPIRES_IN=1d

# Bcrypt cost factor for password hashing (optional; default 12; must be 4–31)
BCRYPT_SALT_ROUNDS=12

# Rate limiting (@nestjs/throttler, in-memory per IP). Set THROTTLE_ENABLED=false to disable (e.g. tests).
THROTTLE_ENABLED=true
# Default window (ms) and max requests per IP per window for most routes
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=100
# Stricter limits for POST /auth/sign-up and POST /auth/login
THROTTLE_AUTH_TTL_MS=60000
THROTTLE_AUTH_LIMIT=10
